# Copie para .env e preencha. Sem as chaves o sistema funciona em modo
# historico (backtest completo); os coletores de odds correntes e fixtures
# ficam inativos e avisam.

# https://the-odds-api.com/ (plano free: 500 creditos/mes)
ODDS_API_KEY=

# https://www.football-data.org/client/register (free tier: 10 req/min)
FOOTBALL_DATA_ORG_KEY=
